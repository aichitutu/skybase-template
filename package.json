{
  "name": "skybase-template",
  "version": "0.1.86",
  "description": "fast skybase project build",
  "bin": {
    "skybase": "./bin/create-skybase.js"
  },
  "files": [
    "bin",
    "config",
    "lib",
    "middleware",
    "model",
    "router",
    "service",
    "template",
    "tests",
    "tool",
    "www",
    "*.js",
    "*.js.tpl",
    "*.yml.tpl",
    ".editorconfig",
    ".eslintignore",
    ".eslintrc",
    ".gitignore",
    ".istanbul.yml",
    ".opencode",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "start": "nodemon index.js",
    "test": "mocha ./tests/*.js",
    "apitest": "node ./tool/scanNoParam.js",
    "cz": "conventional-changelog -p atom -i CHANGELOG.md -s -r 0 && git add . && git status && git cz",
    "push": "npm version patch && npm publish . && git push",
    "inject": "node ./tool/api-string-scan.js",
    "db:update": "node ./sql/migration.js local update 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kongnet/skybase-template.git"
  },
  "keywords": [
    "skybase",
    "template"
  ],
  "author": "9601698@qq.com",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kongnet/skybase-template/issues"
  },
  "homepage": "https://github.com/kongnet/skybase-template#readme",
  "devDependencies": {
    "babel-eslint": "^10.1.0",
    "cz-jt": "^0.1.11",
    "mocha": "^9.1.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-jt"
    }
  },
  "dependencies": {
    "amqplib": "*",
    "axios": "*",
    "cz-jt": "*",
    "https-proxy-agent": "^7.0.6",
    "ioredis": "^4.9.5",
    "j2sql2": "*",
    "meeko": "*",
    "mockjs": "*",
    "mysql2": "^3.18.2",
    "skybase": "*",
    "skyrts": "*",
    "speakeasy": "*",
    "standard": "^12.0.1",
    "svg-captcha": "^1.4.0"
  },
  "standard": {
    "globals": [
      "$",
      "describe",
      "it",
      "define",
      "db"
    ],
    "ignore": [
      "/lib/tpl.js",
      "/lib/Snowflake.js"
    ]
  }
}
